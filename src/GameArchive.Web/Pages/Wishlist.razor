@page "/wishlist"
@inject HttpClient Http
@inject NavigationManager Nav

<!-- Modal de confirmación -->
@if (itemToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-title">¿Eliminar artículo?</div>
            <div class="modal-body">
                Vas a eliminar <strong>@itemToDelete.Name</strong> de la lista de deseos. Esta acción no se puede deshacer.
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CancelDelete">Cancelar</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">Eliminar</button>
            </div>
        </div>
    </div>
}

<div class="page-header">
    <div>
        <div class="page-title">Lista de deseos</div>
        <div class="page-subtitle">@(items?.Count ?? 0) artículos que quieres conseguir</div>
    </div>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/items/new?wishlist=true")'>
        + Añadir a la lista
    </button>
</div>

<div class="filters-bar">
    <input class="search-input" placeholder="Buscar en la lista…" @bind="searchTerm" @bind:event="oninput" @bind:after="LoadItems" />
    <select @bind="filterType" @bind:after="LoadItems">
        <option value="">Todos los tipos</option>
        <option value="Game">Juego</option>
        <option value="Console">Consola</option>
    </select>
</div>

@if (items == null)
{
    <div class="spinner-center"><div class="spinner"></div></div>
}
else if (!items.Any())
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">♡</div>
            <div class="empty-title">La lista de deseos está vacía</div>
            <div class="empty-desc">Registra los juegos y consolas que estás buscando.</div>
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/items/new?wishlist=true")'>+ Añadir a la lista</button>
        </div>
    </div>
}
else
{
    <div class="wishlist-grid">
        @foreach (var item in items)
        {
            <div class="wish-card" @onclick='() => Nav.NavigateTo($"/items/{item.Id}")'>
                <div style="display:flex;justify-content:space-between;align-items:flex-start">
                    <span class="badge @(item.Type == "Game" ? "badge-game" : "badge-console")">
                        @(item.Type == "Game" ? "Juego" : "Consola")
                    </span>
                    <button class="btn btn-danger btn-sm" @onclick:stopPropagation @onclick="() => AskDelete(item)">✕</button>
                </div>
                <div class="wish-card-title">@item.Name</div>
                <div class="wish-card-meta">@item.Platform · @item.Region</div>
                @if (item.EstimatedValue.HasValue)
                {
                    <div class="wish-card-value">€@item.EstimatedValue.Value.ToString("F2")</div>
                }
                @if (!string.IsNullOrWhiteSpace(item.Notes))
                {
                    <div class="wish-card-notes">@item.Notes</div>
                }
                <div style="margin-top:14px">
                    <button class="btn btn-secondary btn-sm" @onclick:stopPropagation @onclick="() => MarkOwned(item)">
                        ✓ Marcar como adquirido
                    </button>
                </div>
            </div>
        }
    </div>
}

@code {
    List<CollectionItemDto>? items;
    string searchTerm = "", filterType = "";
    CollectionItemDto? itemToDelete;

    protected override async Task OnInitializedAsync() => await LoadItems();

    async Task LoadItems()
    {
        var q = new List<string> { "status=Wishlist" };
        if (!string.IsNullOrWhiteSpace(searchTerm)) q.Add($"search={Uri.EscapeDataString(searchTerm)}");
        if (!string.IsNullOrWhiteSpace(filterType)) q.Add($"type={filterType}");
        items = await Http.GetFromJsonAsync<List<CollectionItemDto>>("api/items?" + string.Join("&", q)) ?? [];
    }

    async Task MarkOwned(CollectionItemDto item)
    {
        await Http.PostAsync($"api/items/{item.Id}/toggle-status", null);
        await LoadItems();
    }

    void AskDelete(CollectionItemDto item) => itemToDelete = item;
    void CancelDelete() => itemToDelete = null;

    async Task ConfirmDelete()
    {
        if (itemToDelete == null) return;
        await Http.DeleteAsync($"api/items/{itemToDelete.Id}");
        itemToDelete = null;
        await LoadItems();
    }
}
