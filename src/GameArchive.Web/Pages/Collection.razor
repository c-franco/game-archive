@page "/collection"
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Nav
@using GameArchive.Web.Resources
@using GameArchive.Web.Shared

@if (itemToDelete != null)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-title">@AppStrings.Modal.DeleteTitle</div>
            <div class="modal-body">
                Vas a eliminar <strong>@itemToDelete.Name</strong>. Esta acción no se puede deshacer.
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="CancelDelete">@AppStrings.Modal.CancelLabel</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">@AppStrings.Modal.DeleteConfirmLabel</button>
            </div>
        </div>
    </div>
}

@* Overlay invisible que cierra cualquier dropdown al hacer clic fuera *@
@if (openDropdown != null)
{
    <div class="dropdown-dismiss-overlay" @onclick="CloseDropdown"></div>
}

<div class="page-header">
    <div>
        <div class="page-title">@AppStrings.Collection.Title</div>
        <div class="page-subtitle">
            @CollectionSubtitle
            @if (TotalEstimatedValue > 0)
            {
                <span class="total-value-badge"> · Valor total estimado: @FormatHelper.FormatPrice(TotalEstimatedValue)</span>
            }
        </div>
    </div>
    <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/items/new")'>
        @AppStrings.Collection.AddItem
    </button>
</div>

<!-- ── Fila 1: buscador + sort ──────────────────────────────────────────────── -->
<div class="filters-row-1">
    <div class="search-wrapper">
        <span class="search-icon">⌕</span>
        <input class="search-input-d"
               placeholder="@AppStrings.Collection.SearchPlaceholder"
               @bind="searchTerm" @bind:event="oninput" @bind:after="OnFilterChanged" />
        @if (!string.IsNullOrEmpty(searchTerm))
        {
            <button class="search-clear" @onclick="ClearSearch">✕</button>
        }
    </div>

    <div class="sort-group">
        <select class="sort-select" @bind="sortBy" @bind:after="OnSortChanged">
            <option value="name">@AppStrings.Collection.SortName</option>
            <option value="date">@AppStrings.Collection.SortDate</option>
            <option value="price">@AppStrings.Collection.SortPrice</option>
            <option value="value">@AppStrings.Collection.SortValue</option>
            <option value="platform">@AppStrings.Collection.SortPlatform</option>
        </select>
        <button class="btn btn-secondary btn-sm sort-dir-btn" @onclick="ToggleSort"
                title="@(descending ? "Descendente" : "Ascendente")">
            @(descending ? "↓" : "↑")
        </button>
    </div>
</div>

<!-- ── Fila 2: botones de categoría ────────────────────────────────────────── -->
<div class="filters-row-2">

    <!-- Tipo (selección única) -->
    <div class="filter-dropdown-wrap">
        <button class="filter-cat-btn @(filterType != "" ? "active" : "")"
                @onclick='e => ToggleDropdown("type")'>
            @TypeLabel
            <span class="cat-arrow">▾</span>
        </button>
        @if (openDropdown == "type")
        {
            <div class="filter-dropdown">
                <div class="filter-dropdown-item @(filterType == "" ? "selected" : "")"
                     @onclick='async () => await SetSingleFilter("type", "")'>
                    <span class="fdi-dot"></span>@AppStrings.Collection.FilterAllTypes
                </div>
                <div class="filter-dropdown-item @(filterType == "Game" ? "selected" : "")"
                     @onclick='async () => await SetSingleFilter("type", "Game")'>
                    <span class="fdi-dot"></span>@AppStrings.Common.TypeGame
                </div>
                <div class="filter-dropdown-item @(filterType == "Console" ? "selected" : "")"
                     @onclick='async () => await SetSingleFilter("type", "Console")'>
                    <span class="fdi-dot"></span>@AppStrings.Common.TypeConsole
                </div>
            </div>
        }
    </div>

    <!-- Plataforma (selección múltiple) -->
    <div class="filter-dropdown-wrap">
        <button class="filter-cat-btn @(filterPlatforms.Count > 0 ? "active" : "")"
                @onclick='e => ToggleDropdown("platform")'>
            @PlatformLabel
            @if (filterPlatforms.Count > 1)
            {
                <span class="filter-count-badge">@filterPlatforms.Count</span>
            }
            <span class="cat-arrow">▾</span>
        </button>
        @if (openDropdown == "platform")
        {
            <div class="filter-dropdown filter-dropdown-multi">
                @foreach (var p in platforms)
                {
                    var pCopy     = p;
                    var isChecked = filterPlatforms.Contains(pCopy);
                    <div class="filter-dropdown-item filter-check-item @(isChecked ? "selected" : "")"
                         @onclick='async () => await ToggleMultiFilter(filterPlatforms, pCopy)'>
                        <span class="fdi-checkbox @(isChecked ? "checked" : "")">@(isChecked ? "✓" : "")</span>
                        @pCopy
                    </div>
                }
                @if (filterPlatforms.Count > 0)
                {
                    <div class="dropdown-footer">
                        <button class="btn-clear-dropdown"
                                @onclick='async () => await ClearMultiFilter(filterPlatforms)'>
                            Limpiar selección
                        </button>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Región (selección múltiple) -->
    <div class="filter-dropdown-wrap">
        <button class="filter-cat-btn @(filterRegions.Count > 0 ? "active" : "")"
                @onclick='e => ToggleDropdown("region")'>
            @RegionLabel
            @if (filterRegions.Count > 1)
            {
                <span class="filter-count-badge">@filterRegions.Count</span>
            }
            <span class="cat-arrow">▾</span>
        </button>
        @if (openDropdown == "region")
        {
            <div class="filter-dropdown filter-dropdown-multi">
                @foreach (var (val, label) in RegionOptions)
                {
                    var vCopy     = val;
                    var lCopy     = label;
                    var isChecked = filterRegions.Contains(vCopy);
                    <div class="filter-dropdown-item filter-check-item @(isChecked ? "selected" : "")"
                         @onclick='async () => await ToggleMultiFilter(filterRegions, vCopy)'>
                        <span class="fdi-checkbox @(isChecked ? "checked" : "")">@(isChecked ? "✓" : "")</span>
                        @lCopy
                    </div>
                }
                @if (filterRegions.Count > 0)
                {
                    <div class="dropdown-footer">
                        <button class="btn-clear-dropdown"
                                @onclick='async () => await ClearMultiFilter(filterRegions)'>
                            Limpiar selección
                        </button>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Condición (selección única) -->
    <div class="filter-dropdown-wrap">
        <button class="filter-cat-btn @(filterCondition != "" ? "active" : "")"
                @onclick='e => ToggleDropdown("condition")'>
            @(filterCondition == "" ? AppStrings.Collection.FilterAllConditions : TranslateCondition(filterCondition))
            <span class="cat-arrow">▾</span>
        </button>
        @if (openDropdown == "condition")
        {
            <div class="filter-dropdown">
                <div class="filter-dropdown-item @(filterCondition == "" ? "selected" : "")"
                     @onclick='async () => await SetSingleFilter("condition", "")'>
                    <span class="fdi-dot"></span>@AppStrings.Collection.FilterAllConditions
                </div>
                @foreach (var (val, label) in ConditionOptions)
                {
                    var vCopy = val; var lCopy = label;
                    <div class="filter-dropdown-item @(filterCondition == vCopy ? "selected" : "")"
                         @onclick='async () => await SetSingleFilter("condition", vCopy)'>
                        <span class="fdi-dot"></span>@lCopy
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- ── Fila 3: chips de filtros activos ────────────────────────────────────── -->
@if (ActiveChips.Any())
{
    <div class="active-chips-row">
        @foreach (var (key, value, label) in ActiveChips)
        {
            var keyCopy   = key;
            var valueCopy = value;
            <span class="filter-chip">
                @label
                <button class="chip-remove"
                        @onclick='async () => await RemoveChip(keyCopy, valueCopy)'>✕</button>
            </span>
        }
        <button class="btn-clear-all" @onclick="ClearAllFilters">Limpiar todo</button>
    </div>
}

<!-- ── Tabla ────────────────────────────────────────────────────────────────── -->
@if (items == null)
{
    <div class="spinner-center"><div class="spinner"></div></div>
}
else if (!items.Any())
{
    <div class="card">
        <div class="empty-state">
            <div class="empty-icon">@AppStrings.Collection.EmptyIcon</div>
            <div class="empty-title">@AppStrings.Collection.EmptyTitle</div>
            <div class="empty-desc">@AppStrings.Collection.EmptyDesc</div>
            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/items/new")'>
                @AppStrings.Collection.AddItem
            </button>
        </div>
    </div>
}
else
{
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>@AppStrings.Collection.ColName</th>
                    <th>@AppStrings.Collection.ColType</th>
                    <th>@AppStrings.Collection.ColPlatform</th>
                    <th>@AppStrings.Collection.ColRegion</th>
                    <th>@AppStrings.Collection.ColCondition</th>
                    <th>@AppStrings.Collection.ColPurchasePrice</th>
                    <th>@AppStrings.Collection.ColEstimatedValue</th>
                    <th>@AppStrings.Collection.ColChecklist</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in VisibleItems)
                {
                    var checkedCount = item.ChecklistEntries.Count(e => e.IsChecked);
                    var totalCount   = item.ChecklistEntries.Count;
                    <tr @onclick='() => Nav.NavigateTo($"/items/{item.Id}")'>
                        <td class="td-name">@item.Name</td>
                        <td>
                            <span class="badge @(item.Type == "Game" ? "badge-game" : "badge-console")">
                                @(item.Type == "Game" ? AppStrings.Common.TypeGame : AppStrings.Common.TypeConsole)
                            </span>
                        </td>
                        <td class="td-muted">@item.Platform</td>
                        <td class="td-muted">@item.Region</td>
                        <td class="td-muted">@TranslateCondition(item.Condition)</td>
                        <td class="td-muted">@FormatHelper.FormatPrice(item.PurchasePrice)</td>
                        <td class="td-muted">@FormatHelper.FormatPrice(item.EstimatedValue)</td>
                        <td>
                            @if (totalCount > 0)
                            {
                                <span class="badge @(checkedCount == totalCount ? "badge-full" : "badge-partial")">
                                    @checkedCount/@totalCount
                                </span>
                            }
                        </td>
                        <td @onclick:stopPropagation style="display:flex;gap:6px;padding:8px 16px">
                            <button class="btn btn-secondary btn-sm"
                                    @onclick='() => Nav.NavigateTo($"/items/{item.Id}")'>✎</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => AskDelete(item)">✕</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="table-pagination-footer">
            <div class="pagination-summary">@PaginationSummary</div>

            <div class="pagination-nav">
                <button class="pagination-arrow"
                        @onclick="PreviousPage"
                        disabled="@(currentPage == 1)">
                    &lt;
                </button>

                @foreach (var page in PageNumbers)
                {
                    var pageCopy = page;
                    <button class="pagination-page @(pageCopy == currentPage ? "active" : "")"
                            @onclick="() => GoToPage(pageCopy)">
                        @pageCopy
                    </button>
                }

                <button class="pagination-arrow"
                        @onclick="NextPage"
                        disabled="@(currentPage == TotalPages)">
                    &gt;
                </button>
            </div>

            <div class="pagination-size">
                <span>Artículos por página</span>
                <select @bind="pageSize" @bind:after="OnPageSizeChanged">
                    @foreach (var size in PageSizeOptions)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
            </div>
        </div>
    </div>
}

@code {
    List<CollectionItemDto>? items;
    List<string> platforms = [];
    List<string> regions = [];

    string          searchTerm      = "";
    string          filterType      = "";
    HashSet<string> filterPlatforms = [];
    HashSet<string> filterRegions   = [];
    string          filterCondition = "";
    string          sortBy          = "name";
    bool            descending      = false;
    int             currentPage     = 1;
    int             pageSize        = 20;

    string? openDropdown = null;

    CollectionItemDto? itemToDelete;

    const string SortByStorageKey     = "collection.sortBy";
    const string SortDescStorageKey   = "collection.sortDesc";
    const string PageSizeStorageKey   = "collection.pageSize";
    static readonly HashSet<string> ValidSortFields = ["name", "date", "price", "value", "platform"];
    static readonly int[] PageSizeOptions = [10, 15, 20];

    // ── Opciones estáticas ─────────────────────────────────────────────────────

    IEnumerable<(string val, string label)> RegionOptions
        => regions.Select(r => (r, r));

    static (string val, string label)[] ConditionOptions =>
    [
        ("New",  AppStrings.Common.ConditionNew),
        ("VeryGood", AppStrings.Common.ConditionVeryGood),
        ("Good", AppStrings.Common.ConditionGood),
        ("Fair", AppStrings.Common.ConditionFair),
        ("Poor", AppStrings.Common.ConditionPoor),
    ];

    // ── Labels dinámicos ──────────────────────────────────────────────────────

    string TypeLabel => filterType == ""
        ? AppStrings.Collection.FilterAllTypes
        : filterType == "Game" ? AppStrings.Common.TypeGame : AppStrings.Common.TypeConsole;

    string PlatformLabel => filterPlatforms.Count == 0
        ? AppStrings.Collection.FilterAllPlatforms
        : filterPlatforms.First();

    string RegionLabel => filterRegions.Count == 0
        ? AppStrings.Collection.FilterAllRegions
        : filterRegions.First();

    string CollectionSubtitle => items is null
        ? string.Empty
        : AppStrings.Collection.SubtitleFmt(items.Count);

    decimal? TotalEstimatedValue => items?.Sum(i => i.EstimatedValue ?? 0);

    int TotalPages => items is null || items.Count == 0
        ? 1
        : (int)Math.Ceiling(items.Count / (double)pageSize);

    IEnumerable<int> PageNumbers => Enumerable.Range(1, TotalPages);

    int PageStartIndex => items is null || items.Count == 0
        ? 0
        : ((currentPage - 1) * pageSize) + 1;

    int PageEndIndex => items is null || items.Count == 0
        ? 0
        : Math.Min(currentPage * pageSize, items.Count);

    string PaginationSummary => items is null || items.Count == 0
        ? string.Empty
        : $"{PageStartIndex}\u2013{PageEndIndex} de {AppStrings.Common.ItemCountFmt(items.Count)}";

    IEnumerable<CollectionItemDto> VisibleItems => items?
        .Skip((currentPage - 1) * pageSize)
        .Take(pageSize)
        ?? Enumerable.Empty<CollectionItemDto>();

    // ── Chips activos ─────────────────────────────────────────────────────────

    IEnumerable<(string key, string value, string label)> ActiveChips
    {
        get
        {
            if (!string.IsNullOrEmpty(filterType))
                yield return ("type", filterType, TypeLabel);

            foreach (var p in filterPlatforms.OrderBy(x => x))
                yield return ("platform", p, p);

            foreach (var r in filterRegions.OrderBy(x => x))
            {
                var lbl = RegionOptions.FirstOrDefault(x => x.val == r).label ?? r;
                yield return ("region", r, lbl);
            }

            if (!string.IsNullOrEmpty(filterCondition))
                yield return ("condition", filterCondition, TranslateCondition(filterCondition));
        }
    }

    // ── Ciclo de vida ─────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await LoadSavedSortPreferences();
        await LoadSavedPageSize();
        await LoadPlatforms();
        await LoadRegions();
        await LoadItems();
    }

    async Task LoadSavedSortPreferences()
    {
        var savedSortBy = await JS.InvokeAsync<string?>("localStorage.getItem", SortByStorageKey);
        if (!string.IsNullOrWhiteSpace(savedSortBy) && ValidSortFields.Contains(savedSortBy))
            sortBy = savedSortBy;

        var savedDescending = await JS.InvokeAsync<string?>("localStorage.getItem", SortDescStorageKey);
        if (bool.TryParse(savedDescending, out var isDescending))
            descending = isDescending;
    }

    async Task SaveSortPreferences()
    {
        await JS.InvokeVoidAsync("localStorage.setItem", SortByStorageKey, sortBy);
        await JS.InvokeVoidAsync("localStorage.setItem", SortDescStorageKey, descending.ToString());
    }

    async Task LoadSavedPageSize()
    {
        var savedPageSize = await JS.InvokeAsync<string?>("localStorage.getItem", PageSizeStorageKey);
        if (int.TryParse(savedPageSize, out var parsedPageSize) && PageSizeOptions.Contains(parsedPageSize))
            pageSize = parsedPageSize;
    }

    async Task SavePageSize()
        => await JS.InvokeVoidAsync("localStorage.setItem", PageSizeStorageKey, pageSize.ToString());

    async Task LoadPlatforms()
    {
        var availablePlatforms = await Http.GetFromJsonAsync<List<PlatformDto>>("api/platforms") ?? [];

        platforms = availablePlatforms
            .Select(p => p.Name)
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Union(filterPlatforms)
            .Distinct()
            .OrderBy(p => p)
            .ToList();
    }

    async Task LoadRegions()
    {
        var availableRegions = await Http.GetFromJsonAsync<List<RegionDto>>("api/regions") ?? [];

        regions = availableRegions
            .Select(r => r.Name)
            .Where(r => !string.IsNullOrWhiteSpace(r))
            .Union(filterRegions)
            .Distinct()
            .OrderBy(r => r)
            .ToList();
    }

    async Task LoadItems()
    {
        items = await Http.GetFromJsonAsync<List<CollectionItemDto>>(BuildUrl()) ?? [];
        EnsureValidPage();

        if (platforms.Count == 0)
        {
            platforms = items.Select(i => i.Platform)
                             .Where(p => !string.IsNullOrWhiteSpace(p))
                             .Union(filterPlatforms)
                             .Distinct()
                             .OrderBy(p => p)
                             .ToList();
        }

        if (regions.Count == 0)
        {
            regions = items.Select(i => i.Region)
                           .Where(r => !string.IsNullOrWhiteSpace(r))
                           .Union(filterRegions)
                           .Distinct()
                           .OrderBy(r => r)
                           .ToList();
        }

        StateHasChanged();
    }

    string BuildUrl()
    {
        var q = new List<string> { "status=Owned" };

        if (!string.IsNullOrWhiteSpace(searchTerm))
            q.Add($"search={Uri.EscapeDataString(searchTerm)}");

        if (!string.IsNullOrWhiteSpace(filterType))
            q.Add($"type={filterType}");

        foreach (var p in filterPlatforms)
            q.Add($"platform={Uri.EscapeDataString(p)}");

        foreach (var r in filterRegions)
            q.Add($"region={Uri.EscapeDataString(r)}");

        if (!string.IsNullOrWhiteSpace(filterCondition))
            q.Add($"condition={filterCondition}");

        q.Add($"sortBy={sortBy}&desc={descending.ToString().ToLower()}");
        return "api/items?" + string.Join("&", q);
    }

    // ── Interacciones ─────────────────────────────────────────────────────────

    async Task OnFilterChanged() => await LoadItems();

    async Task OnSortChanged()
    {
        currentPage = 1;
        await SaveSortPreferences();
        await LoadItems();
    }

    async Task ToggleSort()
    {
        descending = !descending;
        currentPage = 1;
        await SaveSortPreferences();
        await LoadItems();
    }

    async Task OnPageSizeChanged()
    {
        currentPage = 1;
        await SavePageSize();
    }

    void ToggleDropdown(string name)
        => openDropdown = openDropdown == name ? null : name;

    void CloseDropdown() => openDropdown = null;

    async Task SetSingleFilter(string key, string value)
    {
        if (key == "type")      filterType      = value;
        if (key == "condition") filterCondition = value;
        currentPage = 1;
        openDropdown = null;
        await LoadItems();
    }

    async Task ToggleMultiFilter(HashSet<string> set, string value)
    {
        if (!set.Remove(value)) set.Add(value);
        currentPage = 1;
        await LoadItems();
    }

    async Task ClearMultiFilter(HashSet<string> set)
    {
        set.Clear();
        currentPage = 1;
        await LoadItems();
    }

    async Task RemoveChip(string key, string value)
    {
        switch (key)
        {
            case "type":      filterType = "";               break;
            case "platform":  filterPlatforms.Remove(value); break;
            case "region":    filterRegions.Remove(value);   break;
            case "condition": filterCondition = "";          break;
        }
        currentPage = 1;
        await LoadItems();
    }

    async Task ClearAllFilters()
    {
        filterType      = "";
        filterCondition = "";
        filterPlatforms.Clear();
        filterRegions.Clear();
        currentPage = 1;
        await LoadItems();
    }

    async Task ClearSearch()
    {
        searchTerm = "";
        currentPage = 1;
        await LoadItems();
    }

    void AskDelete(CollectionItemDto item) => itemToDelete = item;
    void CancelDelete() => itemToDelete = null;

    async Task ConfirmDelete()
    {
        if (itemToDelete == null) return;
        await Http.DeleteAsync($"api/items/{itemToDelete.Id}");
        itemToDelete = null;
        await LoadItems();
    }

    void GoToPage(int page)
    {
        currentPage = Math.Min(Math.Max(page, 1), TotalPages);
    }

    void PreviousPage()
    {
        if (currentPage > 1)
            currentPage--;
    }

    void NextPage()
    {
        if (currentPage < TotalPages)
            currentPage++;
    }

    void EnsureValidPage()
    {
        if (currentPage < 1)
            currentPage = 1;
        else if (currentPage > TotalPages)
            currentPage = TotalPages;
    }

    static string TranslateCondition(string c) => c switch
    {
        "New"  => AppStrings.Common.ConditionNew,
        "VeryGood" => AppStrings.Common.ConditionVeryGood,
        "Good" => AppStrings.Common.ConditionGood,
        "Fair" => AppStrings.Common.ConditionFair,
        "Poor" => AppStrings.Common.ConditionPoor,
        _      => c
    };
}
