@page "/settings"
@inject HttpClient Http

<div class="page-header">
    <div>
        <div class="page-title">Ajustes</div>
    </div>
</div>

@if (templates == null || platforms == null)
{
    <div class="spinner-center"><div class="spinner"></div></div>
}
else
{
    <!-- ── Checklist templates ─────────────────────────────────────────────── -->
    @foreach (var itemType in new[] { "Game", "Console" })
    {
        var label = itemType == "Game" ? "Juego" : "Consola";
        var group = templates.Where(t => t.ItemType == itemType).OrderBy(t => t.SortOrder).ToList();

        <div class="card" style="margin-bottom:20px">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
                <div style="font-weight:600;font-size:0.95rem">
                    <span class="badge @(itemType == "Game" ? "badge-game" : "badge-console")" style="margin-right:8px">@label</span>
                    Plantilla de checklist
                </div>
                <button class="btn btn-secondary btn-sm" @onclick="() => AddTemplate(itemType)">+ Añadir artículo</button>
            </div>

            @if (!group.Any())
            {
                <div style="color:var(--text-3);font-size:0.875rem;padding:12px 0">
                    Sin artículos en la plantilla. Los nuevos artículos de tipo @label tendrán el checklist vacío.
                </div>
            }
            else
            {
                <div style="display:flex;flex-direction:column;gap:8px">
                    @foreach (var t in group)
                    {
                        <div style="display:flex;gap:10px;align-items:center">
                            <input style="max-width:320px"
                                   value="@t.Label"
                                   @onchange="e => UpdateTemplate(t, e.Value?.ToString() ?? t.Label)"
                                   placeholder="Etiqueta…" />
                            <input type="number" style="max-width:80px" title="Orden"
                                   value="@t.SortOrder"
                                   @onchange="e => UpdateTemplateOrder(t, e.Value?.ToString())" />
                            <button class="btn btn-danger btn-sm" @onclick="() => DeleteTemplate(t.Id)">✕</button>
                        </div>
                    }
                </div>
            }
        </div>
    }

    <!-- ── Platforms ──────────────────────────────────────────────────────── -->
    <div class="card" style="margin-bottom:20px">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px">
            <div style="font-weight:600;font-size:0.95rem">Plataformas</div>
            <button class="btn btn-secondary btn-sm" @onclick="AddPlatform">+ Añadir plataforma</button>
        </div>

        @if (!platforms.Any())
        {
            <div style="color:var(--text-3);font-size:0.875rem;padding:12px 0">
                Sin plataformas configuradas. Añade al menos una para poder seleccionarla al crear artículos.
            </div>
        }
        else
        {
            <div style="display:flex;flex-direction:column;gap:8px">
                @foreach (var p in platforms.OrderBy(p => p.SortOrder))
                {
                    <div style="display:flex;gap:10px;align-items:center">
                        <input style="max-width:320px"
                               value="@p.Name"
                               @onchange="e => UpdatePlatform(p, e.Value?.ToString() ?? p.Name)"
                               placeholder="Nombre de la plataforma…" />
                        <input type="number" style="max-width:80px" title="Orden"
                               value="@p.SortOrder"
                               @onchange="e => UpdatePlatformOrder(p, e.Value?.ToString())" />
                        <button class="btn btn-danger btn-sm" @onclick="() => DeletePlatform(p.Id)">✕</button>
                    </div>
                }
            </div>
        }
    </div>

    <!-- ── Importar / Exportar ────────────────────────────────────────────── -->
    <div class="card" style="margin-bottom:20px">
        <div style="font-weight:600;font-size:0.95rem;margin-bottom:8px">Importar / Exportar datos</div>
        <p style="font-size:0.875rem;color:var(--text-2);margin-bottom:20px">
            Exporta tu colección o importa artículos desde un fichero CSV o JSON compatible.
            La importación actualiza los artículos existentes (por ID) y crea los nuevos.
        </p>

        <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">

            <!-- Exportar -->
            <div>
                <div style="font-size:0.78rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-2);margin-bottom:10px">Exportar</div>
                <div style="display:flex;gap:10px">
                    <a href="api/export/csv"  class="btn btn-secondary" target="_blank">↓ CSV</a>
                    <a href="api/export/json" class="btn btn-secondary" target="_blank">↓ JSON</a>
                </div>
            </div>

            <!-- Importar -->
            <div>
                <div style="font-size:0.78rem;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-2);margin-bottom:10px">Importar</div>
                <div style="display:flex;gap:10px">
                    <label class="btn btn-secondary" style="cursor:pointer">
                        ↑ CSV
                        <InputFile OnChange='e => OnFileSelected(e, "csv")' accept=".csv" style="display:none"" />
                    </label>
                    <label class="btn btn-secondary" style="cursor:pointer">
                        ↑ JSON
                        <InputFile OnChange='e => OnFileSelected(e, "json")' accept=".json" style="display:none" />
                    </label>
                </div>
            </div>
        </div>

        <!-- Import progress / result -->
        @if (importing)
        {
            <div style="margin-top:16px;display:flex;align-items:center;gap:10px;color:var(--text-2);font-size:0.875rem">
                <div class="spinner" style="width:18px;height:18px;border-width:2px"></div>
                Importando…
            </div>
        }

        @if (importResult != null)
        {
            <div style="margin-top:16px">
                @if (importResult.Errors.Count == 0)
                {
                    <div class="alert alert-success">
                        Importación completada — @importResult.Created creado(s), @importResult.Updated actualizado(s).
                    </div>
                }
                else
                {
                    <div class="alert alert-error" style="margin-bottom:8px">
                        Importación con errores — @importResult.Created creado(s), @importResult.Updated actualizado(s).
                    </div>
                    <div style="background:var(--bg);border:1px solid var(--border);border-radius:var(--radius);padding:12px;font-size:0.8rem;color:var(--red);display:flex;flex-direction:column;gap:4px">
                        @foreach (var err in importResult.Errors)
                        {
                            <div>• @err</div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(statusMsg))
    {
        <div class="alert alert-success">@statusMsg</div>
    }
}

@code {
    List<ChecklistTemplateDto>? templates;
    List<PlatformDto>?          platforms;
    string statusMsg = "";

    bool          importing    = false;
    ImportResultDto? importResult = null;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadTemplates(), LoadPlatforms());
    }

    // ── Import ────────────────────────────────────────────────────────────────

    async Task OnFileSelected(InputFileChangeEventArgs e, string format)
    {
        importResult = null;
        importing    = true;
        StateHasChanged();

        try
        {
            var file    = e.File;
            var content = new MultipartFormDataContent();
            var stream  = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            content.Add(new StreamContent(stream), "file", file.Name);

            var resp = await Http.PostAsync($"api/import/{format}", content);
            if (resp.IsSuccessStatusCode)
                importResult = await resp.Content.ReadFromJsonAsync<ImportResultDto>();
            else
                importResult = new ImportResultDto(0, 0, [$"Error del servidor: {resp.StatusCode}"]);
        }
        catch (Exception ex)
        {
            importResult = new ImportResultDto(0, 0, [$"Error inesperado: {ex.Message}"]);
        }
        finally
        {
            importing = false;
        }
    }

    // ── Checklist templates ───────────────────────────────────────────────────

    async Task LoadTemplates()
        => templates = await Http.GetFromJsonAsync<List<ChecklistTemplateDto>>("api/templates") ?? [];

    async Task AddTemplate(string itemType)
    {
        var nextOrder = templates!.Where(t => t.ItemType == itemType).Select(t => t.SortOrder).DefaultIfEmpty(0).Max() + 1;
        await Http.PostAsJsonAsync("api/templates", new
        {
            ItemType  = itemType == "Game" ? 0 : 1,
            Label     = "Nuevo artículo",
            SortOrder = nextOrder
        });
        await LoadTemplates();
        ShowStatus("Plantilla añadida.");
    }

    async Task UpdateTemplate(ChecklistTemplateDto t, string newLabel)
    {
        if (newLabel == t.Label) return;
        await Http.PutAsJsonAsync($"api/templates/{t.Id}", new
        {
            ItemType  = t.ItemType == "Game" ? 0 : 1,
            Label     = newLabel,
            t.SortOrder
        });
        await LoadTemplates();
        ShowStatus("Plantilla actualizada.");
    }

    async Task UpdateTemplateOrder(ChecklistTemplateDto t, string? val)
    {
        if (!int.TryParse(val, out var order) || order == t.SortOrder) return;
        await Http.PutAsJsonAsync($"api/templates/{t.Id}", new
        {
            ItemType  = t.ItemType == "Game" ? 0 : 1,
            t.Label,
            SortOrder = order
        });
        await LoadTemplates();
    }

    async Task DeleteTemplate(Guid id)
    {
        await Http.DeleteAsync($"api/templates/{id}");
        templates = templates!.Where(t => t.Id != id).ToList();
        ShowStatus("Plantilla eliminada.");
    }

    // ── Platforms ─────────────────────────────────────────────────────────────

    async Task LoadPlatforms()
        => platforms = await Http.GetFromJsonAsync<List<PlatformDto>>("api/platforms") ?? [];

    async Task AddPlatform()
    {
        var nextOrder = platforms!.Select(p => p.SortOrder).DefaultIfEmpty(0).Max() + 1;
        await Http.PostAsJsonAsync("api/platforms", new { Name = "Nueva plataforma", SortOrder = nextOrder });
        await LoadPlatforms();
        ShowStatus("Plataforma añadida.");
    }

    async Task UpdatePlatform(PlatformDto p, string newName)
    {
        if (string.IsNullOrWhiteSpace(newName) || newName == p.Name) return;
        await Http.PutAsJsonAsync($"api/platforms/{p.Id}", new { Name = newName, p.SortOrder });
        await LoadPlatforms();
        ShowStatus("Plataforma actualizada.");
    }

    async Task UpdatePlatformOrder(PlatformDto p, string? val)
    {
        if (!int.TryParse(val, out var order) || order == p.SortOrder) return;
        await Http.PutAsJsonAsync($"api/platforms/{p.Id}", new { p.Name, SortOrder = order });
        await LoadPlatforms();
    }

    async Task DeletePlatform(Guid id)
    {
        await Http.DeleteAsync($"api/platforms/{id}");
        platforms = platforms!.Where(p => p.Id != id).ToList();
        ShowStatus("Plataforma eliminada.");
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    void ShowStatus(string msg)
    {
        statusMsg = msg;
        _ = Task.Delay(2500).ContinueWith(_ => { statusMsg = ""; InvokeAsync(StateHasChanged); });
    }

    record ImportResultDto(int Created, int Updated, List<string> Errors);
}
