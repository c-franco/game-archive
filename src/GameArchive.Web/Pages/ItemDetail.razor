@page "/items/new"
@page "/items/{Id:guid}"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime Js
@using GameArchive.Web.Resources

<!-- Modal eliminar -->
@if (showDeleteModal)
{
    <div class="modal-overlay" @onclick="() => showDeleteModal = false">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-title">@AppStrings.Modal.DeleteTitle</div>
            <div class="modal-body">
                Vas a eliminar <strong>@model.Name</strong>. Esta acción no se puede deshacer.
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">
                    @AppStrings.Modal.CancelLabel
                </button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">
                    @AppStrings.Modal.DeleteConfirmLabel
                </button>
            </div>
        </div>
    </div>
}

<div class="page-header">
    <div>
        <div class="page-title">@(IsNew ? AppStrings.ItemDetail.TitleNew : model.Name)</div>
        <div class="page-subtitle">@(IsNew ? AppStrings.ItemDetail.SubtitleNew : AppStrings.ItemDetail.SubtitleEdit)</div>
    </div>
    <button class="btn btn-ghost" @onclick="() => Nav.NavigateTo(BackUrl)">
        @AppStrings.Common.Back
    </button>
</div>

@if (loading)
{
    <div class="spinner-center"><div class="spinner"></div></div>
}
else
{
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success">@successMsg</div>
    }
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-error">@errorMsg</div>
    }

    <div style="display:grid;grid-template-columns:1fr 320px;gap:24px;align-items:start">

        <!-- Formulario principal -->
        <div class="card">
            <div class="form-grid">

                <!-- Nombre -->
                <div class="form-group span-2">
                    <label>@AppStrings.ItemDetail.FieldName</label>
                    <input class="@(errors.ContainsKey("Name") ? "input-error" : "")"
                           @bind="model.Name"
                           @bind:event="oninput"
                           @onblur='() => ValidateField("Name")'
                           placeholder="@AppStrings.ItemDetail.NamePlaceholder" />
                    @if (errors.TryGetValue("Name", out var eName))
                    {
                        <span class="field-error">@eName</span>
                    }
                </div>

                <!-- Tipo -->
                <div class="form-group">
                    <label>@AppStrings.ItemDetail.FieldType</label>
                    <select @bind="model.Type" @bind:after="OnTypeChanged">
                        <option value="Game">@AppStrings.Common.TypeGame</option>
                        <option value="Console">@AppStrings.Common.TypeConsole</option>
                    </select>
                </div>

                <!-- Estado -->
                <div class="form-group form-group-readonly">
                    <label>@AppStrings.ItemDetail.FieldStatus</label>
                    <select class="input-readonly" @bind="model.Status" disabled>
                        <option value="Owned">@AppStrings.Common.StatusOwned</option>
                        <option value="Wishlist">@AppStrings.Common.StatusWishlist</option>
                    </select>
                </div>

                <!-- Plataforma -->
                <div class="form-group">
                    <label>@AppStrings.ItemDetail.FieldPlatform</label>
                    <select class="@(errors.ContainsKey("Platform") ? "input-error" : "")"
                            @bind="model.Platform"
                            @bind:after='() => ValidateField("Platform")'>
                        <option value="">@AppStrings.Common.SelectPlaceholder</option>
                        @foreach (var p in availablePlatforms)
                        {
                            <option value="@p.Name">@p.Name</option>
                        }
                    </select>
                    @if (errors.TryGetValue("Platform", out var ePlatform))
                    {
                        <span class="field-error">@ePlatform</span>
                    }
                </div>

                <!-- Región -->
                <div class="form-group">
                    <label>@AppStrings.ItemDetail.FieldRegion</label>
                    <select class="@(errors.ContainsKey("Region") ? "input-error" : "")"
                            @bind="model.Region"
                            @bind:after='() => ValidateField("Region")'>
                        <option value="">@AppStrings.Common.SelectPlaceholder</option>
                        @foreach (var r in availableRegions)
                        {
                            <option value="@r.Name">@r.Name</option>
                        }
                    </select>
                    @if (errors.TryGetValue("Region", out var eRegion))
                    {
                        <span class="field-error">@eRegion</span>
                    }
                </div>

                <!-- Condición -->
                <div class="form-group">
                    <label>@AppStrings.ItemDetail.FieldCondition</label>
                    <select class="@(errors.ContainsKey("Condition") ? "input-error" : "")"
                            @bind="model.Condition"
                            @bind:after='() => ValidateField("Condition")'>
                        <option value="">@AppStrings.Common.SelectPlaceholder</option>
                        <option value="New">@AppStrings.Common.ConditionNew</option>
                        <option value="VeryGood">@AppStrings.Common.ConditionVeryGood</option>
                        <option value="Good">@AppStrings.Common.ConditionGood</option>
                        <option value="Fair">@AppStrings.Common.ConditionFair</option>
                        <option value="Poor">@AppStrings.Common.ConditionPoor</option>
                    </select>
                    @if (errors.TryGetValue("Condition", out var eCondition))
                    {
                        <span class="field-error">@eCondition</span>
                    }
                </div>

                @if (!IsWishlistItem)
                {
                    <!-- Fecha de compra -->
                    <div class="form-group">
                        <label>@AppStrings.ItemDetail.FieldPurchaseDate</label>
                        <input type="date"
                               class="@(errors.ContainsKey("PurchaseDate") ? "input-error" : "")"
                               @bind="model.PurchaseDate"
                               @bind:after='() => ValidateField("PurchaseDate")'
                               max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                        @if (errors.TryGetValue("PurchaseDate", out var eDate))
                        {
                            <span class="field-error">@eDate</span>
                        }
                    </div>

                    <!-- Precio de compra -->
                    <div class="form-group">
                        <label>@AppStrings.ItemDetail.FieldPurchasePrice</label>
                        <input type="number" step="0.01" min="0"
                               class="@(errors.ContainsKey("PurchasePrice") ? "input-error" : "")"
                               @bind="model.PurchasePrice"
                               @bind:event="oninput"
                               @onblur='() => ValidateField("PurchasePrice")'
                               placeholder="@AppStrings.ItemDetail.PricePlaceholder" />
                        @if (errors.TryGetValue("PurchasePrice", out var ePrice))
                        {
                            <span class="field-error">@ePrice</span>
                        }
                    </div>
                }

                <!-- Valor estimado (opcional) -->
                <div class="form-group">
                    <label>@AppStrings.ItemDetail.FieldEstimatedValue</label>
                    <input type="number" step="0.01" min="0"
                           class="@(errors.ContainsKey("EstimatedValue") ? "input-error" : "")"
                           @bind="model.EstimatedValue"
                           @bind:event="oninput"
                           @onblur='() => ValidateField("EstimatedValue")'
                           placeholder="@AppStrings.ItemDetail.PricePlaceholder" />
                    @if (errors.TryGetValue("EstimatedValue", out var eValue))
                    {
                        <span class="field-error">@eValue</span>
                    }
                </div>

                <!-- Notas (opcional) -->
                <div class="form-group span-2">
                    <label>@AppStrings.ItemDetail.FieldNotes</label>
                    <textarea @bind="model.Notes"
                              placeholder="@AppStrings.ItemDetail.NotesPlaceholder"></textarea>
                </div>

                <!-- URL de PriceCharting (opcional, para scraping manual) -->
                <div class="form-group span-2">
                    <label>@AppStrings.ItemDetail.FieldProductUrl</label>
                    <input type="url" 
                           @bind="model.ProductUrl"
                           placeholder="@AppStrings.ItemDetail.ProductUrlPlaceholder" />
                    <span style="font-size:0.75rem;color:var(--text-2)">
                        @AppStrings.ItemDetail.FieldProductUrlHelp
                    </span>
                </div>

            </div>

            <hr class="divider" />

            <div style="display:flex;justify-content:flex-end;gap:10px">
                @if (!IsNew)
                {
                    <button class="btn btn-danger" @onclick="() => showDeleteModal = true">
                        @AppStrings.Common.Delete
                    </button>
                }
                <button class="btn btn-secondary" @onclick="() => Nav.NavigateTo(BackUrl)">
                    @AppStrings.Common.Cancel
                </button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @(saving ? AppStrings.ItemDetail.SavingLabel
                             : (IsNew ? AppStrings.ItemDetail.SaveNew : AppStrings.ItemDetail.SaveEdit))
                </button>
            </div>
        </div>

        @if (!IsWishlistItem)
        {
        <!-- Columna derecha: Checklist + Botón scrapeo -->
        <div>
            <!-- Checklist -->
            <div class="card">
                <div style="font-weight:600;margin-bottom:14px;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-2)">
                    @AppStrings.ItemDetail.ChecklistTitle
                </div>

                @if (!model.ChecklistEntries.Any())
                {
                    <div style="color:var(--text-3);font-size:0.875rem;text-align:center;padding:24px 0">
                        Sin artículos en el checklist.<br />Configura las plantillas en Ajustes.
                    </div>
                }
                else
                {
                    <div class="checklist">
                        @foreach (var entry in model.ChecklistEntries.OrderBy(e => e.SortOrder))
                        {
                            <div class="checklist-item">
                                <input type="checkbox" id="chk-@entry.Id" @bind="entry.IsChecked" />
                                <label for="chk-@entry.Id">@entry.Label</label>
                            </div>
                        }
                    </div>
                    <div style="margin-top:12px;font-size:0.8rem;color:var(--text-2)">
                        @AppStrings.ItemDetail.ChecklistProgress(
                            model.ChecklistEntries.Count(e => e.IsChecked),
                            model.ChecklistEntries.Count)
                    </div>
                }
            </div>
            
            <!-- Botón scrapear precio (debajo de la card del checklist) -->
            <button class="btn btn-secondary" style="margin-top:12px;width:100%;display:flex;align-items:center;justify-content:center;gap:8px" 
                    @onclick="ScrapePriceAsync" 
                    disabled="@scrapingPrice">
                @if (scrapingPrice)
                {
                    <span class="spinner" style="width:14px;height:14px;border-width:2px;flex-shrink:0"></span>
                    <span>@AppStrings.ItemDetail.ScrapePriceSearching</span>
                }
                else
                {
                    <span>@AppStrings.ItemDetail.ScrapePriceButton</span>
                }
            </button>
        </div>
        }

    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery] public bool Wishlist { get; set; }
    [SupplyParameterFromQuery] public string? ReturnPlatform { get; set; }

    bool IsNew => Id == null;
    bool IsWishlistItem => model.Status == "Wishlist";
    bool loading = true, saving = false;
    bool scrapingPrice = false;
    bool showDeleteModal = false;
    string errorMsg = "", successMsg = "";

    string WishlistReturnUrl => !string.IsNullOrWhiteSpace(ReturnPlatform)
        ? $"/wishlist?platform={Uri.EscapeDataString(ReturnPlatform)}"
        : "/wishlist";

    string BackUrl => model.Status == "Wishlist" ? WishlistReturnUrl : "/collection";

    ItemFormModel      model              = new();
    List<PlatformDto>  availablePlatforms = [];
    List<RegionDto>    availableRegions   = [];
    List<ChecklistTemplateDto> availableTemplates = [];
    Dictionary<string, string> errors     = new();

    // ── Validation ────────────────────────────────────────────────────────────

    void ValidateField(string field)
    {
        errors.Remove(field);

        switch (field)
        {
            case "Name":
                if (string.IsNullOrWhiteSpace(model.Name))
                    errors["Name"] = AppStrings.ItemDetail.ValidationNameRequired;
                else if (model.Name.Trim().Length > 200)
                    errors["Name"] = AppStrings.ItemDetail.ValidationNameMaxLength;
                break;

            case "Platform":
                if (string.IsNullOrWhiteSpace(model.Platform))
                    errors["Platform"] = AppStrings.ItemDetail.ValidationPlatform;
                break;

            case "Region":
                if (string.IsNullOrWhiteSpace(model.Region))
                    errors["Region"] = AppStrings.ItemDetail.ValidationRegion;
                break;

            case "Condition":
                if (string.IsNullOrWhiteSpace(model.Condition))
                    errors["Condition"] = AppStrings.ItemDetail.ValidationCondition;
                break;

            case "PurchaseDate":
                if (IsWishlistItem)
                    break;
                if (!model.PurchaseDate.HasValue)
                    errors["PurchaseDate"] = AppStrings.ItemDetail.ValidationDateRequired;
                else if (model.PurchaseDate.Value.Date > DateTime.Today)
                    errors["PurchaseDate"] = AppStrings.ItemDetail.ValidationDateFuture;
                break;

            case "PurchasePrice":
                if (IsWishlistItem)
                    break;
                if (!model.PurchasePrice.HasValue)
                    errors["PurchasePrice"] = AppStrings.ItemDetail.ValidationPriceRequired;
                else if (model.PurchasePrice.Value < 0)
                    errors["PurchasePrice"] = AppStrings.ItemDetail.ValidationPriceNegative;
                break;

            case "EstimatedValue":
                if (model.EstimatedValue.HasValue && model.EstimatedValue.Value < 0)
                    errors["EstimatedValue"] = AppStrings.ItemDetail.ValidationValueNegative;
                break;
        }
    }

    bool ValidateAll()
    {
        var fields = new List<string> { "Name", "Platform", "Region", "Condition", "EstimatedValue" };

        if (!IsWishlistItem)
        {
            fields.Add("PurchaseDate");
            fields.Add("PurchasePrice");
        }

        foreach (var field in fields)
            ValidateField(field);
        return errors.Count == 0;
    }

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            var context = await Http.GetFromJsonAsync<ItemEditContextDto>($"api/items/{Id}/edit-context");
            if (context == null) { Nav.NavigateTo("/"); return; }

            availablePlatforms = context.Platforms ?? [];
            availableRegions = context.Regions ?? [];

            var item = context.Item;

            model = new ItemFormModel
            {
                Id             = item.Id,
                Name           = item.Name,
                Type           = item.Type,
                Platform       = item.Platform,
                Region         = item.Region,
                Condition      = item.Condition,
                PurchasePrice  = item.PurchasePrice,
                EstimatedValue = item.EstimatedValue,
                PurchaseDate   = item.PurchaseDate,
                Notes          = item.Notes,
                Status         = item.Status,
                ChecklistEntries = item.ChecklistEntries
                    .Select(e => new ChecklistEntryForm
                    {
                        Id = e.Id, Label = e.Label,
                        IsChecked = e.IsChecked, SortOrder = e.SortOrder
                    })
                    .ToList(),
                ProductUrl = item.ProductUrl
            };

            ApplyStatusRules();
        }
        else
        {
            var settingsTask = Http.GetFromJsonAsync<SettingsDto>("api/settings");
            ApplySettings(await settingsTask);
            model.Status = Wishlist ? "Wishlist" : "Owned";
            // Pre-seleccionar la plataforma si venimos desde una vista de plataforma
            if (!string.IsNullOrWhiteSpace(ReturnPlatform))
                model.Platform = ReturnPlatform;
            ApplyStatusRules();
            await LoadChecklistTemplate();
        }

        loading = false;
    }

    Task LoadChecklistTemplate()
    {
        if (IsWishlistItem)
        {
            model.ChecklistEntries = [];
            return Task.CompletedTask;
        }

        model.ChecklistEntries = availableTemplates
            .Where(t => t.ItemType == model.Type)
            .OrderBy(t => t.SortOrder)
            .Select(t => new ChecklistEntryForm
            {
                Id = Guid.NewGuid(), Label = t.Label,
                IsChecked = false, SortOrder = t.SortOrder
            })
            .ToList();
        return Task.CompletedTask;
    }

    async Task OnTypeChanged()
    {
        if (IsNew) await LoadChecklistTemplate();
    }

    void ApplyStatusRules()
    {
        if (!IsWishlistItem)
            return;

        model.PurchaseDate = null;
        model.PurchasePrice = null;
        model.ChecklistEntries = [];
        errors.Remove("PurchaseDate");
        errors.Remove("PurchasePrice");
    }

    // ── Save ──────────────────────────────────────────────────────────────────

    async Task Save()
    {
        successMsg = "";
        errorMsg   = "";

        if (!ValidateAll())
        {
            errorMsg = AppStrings.ItemDetail.SaveErrorForm;
            return;
        }

        saving = true;

        ApplyStatusRules();

        var purchaseDate = model.PurchaseDate.HasValue
            ? DateOnly.FromDateTime(model.PurchaseDate.Value)
            : (DateOnly?)null;
        var purchasePrice = IsWishlistItem ? null : model.PurchasePrice;

        if (IsNew)
        {
            var resp = await Http.PostAsJsonAsync("api/items", new
            {
                model.Name,
                Type           = model.Type == "Game" ? 0 : 1,
                model.Platform,
                model.Region,
                model.Condition,
                PurchasePrice  = purchasePrice,
                model.EstimatedValue,
                PurchaseDate   = purchaseDate,
                model.Notes,
                Status         = model.Status == "Owned" ? 0 : 1,
                ChecklistUpdates = model.ChecklistEntries
                    .Select(e => new { Label = e.Label, IsChecked = e.IsChecked })
                    .ToList(),
                model.ProductUrl
            });

            saving = false;

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo(model.Status == "Wishlist" ? WishlistReturnUrl : "/collection");
                return;
            }
            errorMsg = AppStrings.ItemDetail.SaveErrorServer;
        }
        else
        {
            var resp = await Http.PutAsJsonAsync($"api/items/{Id}", new
            {
                Id             = model.Id,
                model.Name,
                Type           = model.Type == "Game" ? 0 : 1,
                model.Platform,
                model.Region,
                model.Condition,
                PurchasePrice  = purchasePrice,
                model.EstimatedValue,
                PurchaseDate   = purchaseDate,
                model.Notes,
                Status         = model.Status == "Owned" ? 0 : 1,
                ChecklistUpdates = model.ChecklistEntries
                    .Select(e => new { Label = e.Label, IsChecked = e.IsChecked })
                    .ToList(),
                model.ProductUrl
            });

            saving = false;

            if (resp.IsSuccessStatusCode)
                successMsg = AppStrings.ItemDetail.SaveSuccess;
            else
                errorMsg = AppStrings.ItemDetail.SaveErrorEdit;
        }
    }

    async Task ConfirmDelete()
    {
        showDeleteModal = false;
        await Http.DeleteAsync($"api/items/{Id}");
        Nav.NavigateTo(model.Status == "Wishlist" ? WishlistReturnUrl : "/");
    }

    record CreateResult(Guid Id);
    record ItemEditContextDto(
        CollectionItemDto Item,
        List<PlatformDto> Platforms,
        List<RegionDto> Regions);
    record SettingsDto(
        List<ChecklistTemplateDto> Templates,
        List<PlatformDto> Platforms,
        List<RegionDto> Regions);

    void ApplySettings(SettingsDto? settings)
    {
        availableTemplates = settings?.Templates ?? [];
        availablePlatforms = settings?.Platforms ?? [];
        availableRegions = settings?.Regions ?? [];
    }

    // ── Scrape Price ──────────────────────────────────────────────────────────

    async Task ScrapePriceAsync()
    {
        Console.WriteLine("[ScrapePriceAsync] Iniciando...");
        if (IsNew || Id == null)
        {
            Console.WriteLine("[ScrapePriceAsync] Cancelado: es nuevo o sin ID");
            return;
        }

        scrapingPrice = true;
        errorMsg = "";
        successMsg = "";
        StateHasChanged();

        try
        {
            Console.WriteLine($"[ScrapePriceAsync] Llamando al endpoint del backend para item {Id}");
            
            var resp = await Http.PostAsync($"api/price/fetch/{Id}", null);
            
            if (!resp.IsSuccessStatusCode)
            {
                var errorText = await resp.Content.ReadAsStringAsync();
                errorMsg = $"Error del servidor: {resp.StatusCode}";
                Console.WriteLine($"[ScrapePriceAsync] Error HTTP: {resp.StatusCode}, {errorText}");
                return;
            }

            var result = await resp.Content.ReadFromJsonAsync<PriceFetchResponse>();
            
            Console.WriteLine($"[ScrapePriceAsync] Resultado: success={result?.success}, priceEur={result?.priceEur}, error={result?.error}");

            if (result?.success == true && result.priceEur.HasValue)
            {
                model.EstimatedValue = result.priceEur;
                model.ProductUrl = result.productUrl ?? model.ProductUrl;
                successMsg = AppStrings.ItemDetail.ScrapePriceSuccessFmt(result.priceEur.Value, result.condition ?? "Unknown");
            }
            else
            {
                errorMsg = result?.error ?? AppStrings.ItemDetail.ScrapePriceNotFound;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ScrapePriceAsync] Excepción: {ex}");
            errorMsg = AppStrings.ItemDetail.ScrapePriceErrorFmt(ex.Message);
        }
        finally
        {
            scrapingPrice = false;
            StateHasChanged();
        }
    }

    record PriceFetchResponse(bool success, decimal? priceEur, string? condition, string? productUrl, string? error);
}
