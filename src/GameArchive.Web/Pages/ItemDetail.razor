@page "/items/new"
@page "/items/{Id:guid}"
@inject HttpClient Http
@inject NavigationManager Nav

<!-- Modal eliminar -->
@if (showDeleteModal)
{
    <div class="modal-overlay" @onclick="() => showDeleteModal = false">
        <div class="modal-box" @onclick:stopPropagation>
            <div class="modal-title">¿Eliminar artículo?</div>
            <div class="modal-body">
                Vas a eliminar <strong>@model.Name</strong>. Esta acción no se puede deshacer.
            </div>
            <div class="modal-actions">
                <button class="btn btn-secondary" @onclick="() => showDeleteModal = false">Cancelar</button>
                <button class="btn btn-danger" @onclick="ConfirmDelete">Eliminar</button>
            </div>
        </div>
    </div>
}

<div class="page-header">
    <div>
        <div class="page-title">@(IsNew ? "Nuevo artículo" : model.Name)</div>
        <div class="page-subtitle">@(IsNew ? "Añadir a tu colección" : "Editar detalles")</div>
    </div>
    <button class="btn btn-ghost" @onclick="() => Nav.NavigateTo(BackUrl)">← Volver</button>
</div>

@if (loading)
{
    <div class="spinner-center"><div class="spinner"></div></div>
}
else
{
    @if (!string.IsNullOrEmpty(errorMsg))
    {
        <div class="alert alert-error">@errorMsg</div>
    }
    @if (!string.IsNullOrEmpty(successMsg))
    {
        <div class="alert alert-success">@successMsg</div>
    }

    <div style="display:grid;grid-template-columns:1fr 320px;gap:24px;align-items:start">

        <!-- Formulario principal -->
        <div class="card">
            <div class="form-grid">

                <div class="form-group span-2">
                    <label>Nombre *</label>
                    <input @bind="model.Name" placeholder="p.ej. The Legend of Zelda: Ocarina of Time" />
                </div>

                <div class="form-group">
                    <label>Tipo *</label>
                    <select @bind="model.Type" @bind:after="OnTypeChanged">
                        <option value="Game">Juego</option>
                        <option value="Console">Consola</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Estado</label>
                    <select @bind="model.Status">
                        <option value="Owned">Adquirido</option>
                        <option value="Wishlist">Lista de deseos</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Plataforma</label>
                    <input @bind="model.Platform" placeholder="p.ej. SNES, Nintendo 64, PS1…" />
                </div>

                <div class="form-group">
                    <label>Región</label>
                    <select @bind="model.Region">
                        <option value="">— Seleccionar —</option>
                        <option value="PAL">PAL</option>
                        <option value="NTSC-U">NTSC-U</option>
                        <option value="NTSC-J">NTSC-J</option>
                        <option value="NTSC">NTSC</option>
                        <option value="Unknown">Desconocida</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Condición</label>
                    <select @bind="model.Condition">
                        <option value="">— Seleccionar —</option>
                        <option value="New">Nuevo</option>
                        <option value="Good">Bueno</option>
                        <option value="Fair">Regular</option>
                        <option value="Poor">Malo</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Fecha de compra</label>
                    <input type="date" @bind="model.PurchaseDate" />
                </div>

                <div class="form-group">
                    <label>Precio de compra (€)</label>
                    <input type="number" step="0.01" @bind="model.PurchasePrice" placeholder="0.00" />
                </div>

                <div class="form-group">
                    <label>Valor estimado actual (€)</label>
                    <input type="number" step="0.01" @bind="model.EstimatedValue" placeholder="0.00" />
                </div>

                <div class="form-group span-2">
                    <label>Notas</label>
                    <textarea @bind="model.Notes" placeholder="Detalles de la condición, dónde lo conseguiste, número de serie…"></textarea>
                </div>

            </div>

            <hr class="divider" />

            <div style="display:flex;justify-content:flex-end;gap:10px">
                @if (!IsNew)
                {
                    <button class="btn btn-danger" @onclick="() => showDeleteModal = true">Eliminar</button>
                }
                <button class="btn btn-secondary" @onclick="() => Nav.NavigateTo(BackUrl)">Cancelar</button>
                <button class="btn btn-primary" @onclick="Save" disabled="@saving">
                    @(saving ? "Guardando…" : (IsNew ? "Añadir artículo" : "Guardar cambios"))
                </button>
            </div>
        </div>

        <!-- Checklist -->
        <div class="card">
            <div style="font-weight:600;margin-bottom:14px;font-size:0.85rem;text-transform:uppercase;letter-spacing:0.06em;color:var(--text-2)">
                Checklist
            </div>

            @if (!model.ChecklistEntries.Any())
            {
                <div style="color:var(--text-3);font-size:0.875rem;text-align:center;padding:24px 0">
                    Sin artículos en el checklist.<br />Configura las plantillas en Ajustes.
                </div>
            }
            else
            {
                <div class="checklist">
                    @foreach (var entry in model.ChecklistEntries.OrderBy(e => e.SortOrder))
                    {
                        <div class="checklist-item">
                            <input type="checkbox" id="chk-@entry.Id" @bind="entry.IsChecked" />
                            <label for="chk-@entry.Id">@entry.Label</label>
                        </div>
                    }
                </div>
                <div style="margin-top:12px;font-size:0.8rem;color:var(--text-2)">
                    @model.ChecklistEntries.Count(e => e.IsChecked) / @model.ChecklistEntries.Count completados
                </div>
            }
        </div>

    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery] public bool Wishlist { get; set; }

    bool IsNew => Id == null;
    bool loading = true, saving = false;
    bool showDeleteModal = false;
    string errorMsg = "", successMsg = "";
    string BackUrl => model.Status == "Wishlist" ? "/wishlist" : "/collection";

    ItemFormModel model = new();

    protected override async Task OnInitializedAsync()
    {
        if (!IsNew)
        {
            var item = await Http.GetFromJsonAsync<CollectionItemDto>($"api/items/{Id}");
            if (item == null) { Nav.NavigateTo("/"); return; }

            model = new ItemFormModel
            {
                Id             = item.Id,
                Name           = item.Name,
                Type           = item.Type,
                Platform       = item.Platform,
                Region         = item.Region,
                Condition      = item.Condition,
                PurchasePrice  = item.PurchasePrice,
                EstimatedValue = item.EstimatedValue,
                PurchaseDate   = item.PurchaseDate,
                Notes          = item.Notes,
                Status         = item.Status,
                ChecklistEntries = item.ChecklistEntries
                    .Select(e => new ChecklistEntryForm { Id = e.Id, Label = e.Label, IsChecked = e.IsChecked, SortOrder = e.SortOrder })
                    .ToList()
            };
        }
        else
        {
            if (Wishlist) model.Status = "Wishlist";
            await LoadChecklistTemplate();
        }

        loading = false;
    }

    async Task LoadChecklistTemplate()
    {
        var templates = await Http.GetFromJsonAsync<List<ChecklistTemplateDto>>("api/templates") ?? [];
        model.ChecklistEntries = templates
            .Where(t => t.ItemType == model.Type)
            .OrderBy(t => t.SortOrder)
            .Select(t => new ChecklistEntryForm { Id = Guid.NewGuid(), Label = t.Label, IsChecked = false, SortOrder = t.SortOrder })
            .ToList();
    }

    async Task OnTypeChanged()
    {
        if (IsNew) await LoadChecklistTemplate();
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Name)) { errorMsg = "El nombre es obligatorio."; return; }

        saving = true; errorMsg = ""; successMsg = "";

        DateOnly? purchaseDate = null;
        if (model.PurchaseDate.HasValue)
            purchaseDate = DateOnly.FromDateTime(model.PurchaseDate.Value);

        if (IsNew)
        {
            var resp = await Http.PostAsJsonAsync("api/items", new
            {
                model.Name,
                Type           = model.Type == "Game" ? 0 : 1,
                model.Platform,
                model.Region,
                model.Condition,
                model.PurchasePrice,
                model.EstimatedValue,
                PurchaseDate   = purchaseDate,
                model.Notes,
                Status         = model.Status == "Owned" ? 0 : 1
            });

            saving = false;

            if (resp.IsSuccessStatusCode)
            {
                Nav.NavigateTo(model.Status == "Wishlist" ? "/wishlist" : "/collection");
                return;
            }
            errorMsg = "Error al crear el artículo.";
        }
        else
        {
            var resp = await Http.PutAsJsonAsync($"api/items/{Id}", new
            {
                Id             = model.Id,
                model.Name,
                Type           = model.Type == "Game" ? 0 : 1,
                model.Platform,
                model.Region,
                model.Condition,
                model.PurchasePrice,
                model.EstimatedValue,
                PurchaseDate   = purchaseDate,
                model.Notes,
                Status         = model.Status == "Owned" ? 0 : 1,
                ChecklistUpdates = model.ChecklistEntries
                    .Select(e => new { EntryId = e.Id, e.IsChecked })
                    .ToList()
            });

            if (resp.IsSuccessStatusCode) { successMsg = "Cambios guardados correctamente."; }
            else errorMsg = "Error al guardar los cambios.";

            saving = false;
        }
    }

    async Task ConfirmDelete()
    {
        showDeleteModal = false;
        await Http.DeleteAsync($"api/items/{Id}");
        Nav.NavigateTo(model.Status == "Wishlist" ? "/wishlist" : "/");
    }

    record CreateResult(Guid Id);
}
